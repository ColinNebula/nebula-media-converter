# Environment Variables for Nebula Media Converter

# Admin Credentials (Change these in production!)
REACT_APP_ADMIN_USERNAME=your_admin_username
REACT_APP_ADMIN_PASSWORD=your_secure_password_here
REACT_APP_ADMIN_EMAIL=admin@yourdomain.com

# Payment Integration
REACT_APP_PAYPAL_CLIENT_ID=your_paypal_client_id
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key

# API Configuration
REACT_APP_API_BASE_URL=https://api.yourdomain.com
REACT_APP_EMAIL_SERVICE_URL=https://email.yourdomain.com

# Analytics & Monitoring
REACT_APP_ANALYTICS_ID=your_analytics_id
REACT_APP_ERROR_REPORTING_KEY=your_error_reporting_key

# Feature Flags
REACT_APP_ENABLE_PREMIUM_FEATURES=true
REACT_APP_ENABLE_EMAIL_MARKETING=true
REACT_APP_ENABLE_ADMIN_PANEL=true