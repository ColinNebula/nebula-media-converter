# ============================================
# NEBULA MEDIA CONVERTER - ENVIRONMENT CONFIGURATION
# ============================================
# SECURITY WARNING: Never commit .env files with real values!
# Copy this file to .env and fill in your actual values.
# ============================================

# ==========================================
# COMPANY/APP INFORMATION (Public)
# ==========================================
REACT_APP_COMPANY_NAME=Your Company Name
REACT_APP_DEVELOPER_NAME=Your Name
REACT_APP_APP_NAME=Nebula Media Converter
REACT_APP_APP_URL=https://yourdomain.com
REACT_APP_SUPPORT_EMAIL=support@yourdomain.com
REACT_APP_GITHUB_REPO=https://github.com/yourusername/your-repo

# ==========================================
# ADMIN CREDENTIALS — SERVER-SIDE ONLY
# ==========================================
# These are NOT prefixed with REACT_APP_ and are NEVER bundled into client JS.
# They are read only by backend/dev-server.js (Node process).
#
# Generate hash + salt with:
#   node -e "const c=require('crypto'),s=c.randomBytes(32).toString('hex'),h=c.pbkdf2Sync('<your_password>',s,310000,32,'sha256').toString('hex');console.log('ADMIN_PASSWORD_SALT='+s+'\nADMIN_PASSWORD_HASH='+h)"
ADMIN_USERNAME=admin@yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD_SALT=replace_with_generated_salt
ADMIN_PASSWORD_HASH=replace_with_generated_hash

# ==========================================
# PAYMENT INTEGRATION (Sensitive)
# ==========================================
# Get these from your PayPal/Stripe dashboard
# Use test keys for development, live keys for production
REACT_APP_PAYPAL_CLIENT_ID=your_paypal_client_id
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key

# ==========================================
# API CONFIGURATION
# ==========================================
REACT_APP_API_BASE_URL=https://api.yourdomain.com
REACT_APP_EMAIL_SERVICE_URL=https://email.yourdomain.com
REACT_APP_PAYMENT_API=https://payments.yourdomain.com
REACT_APP_CDN_URL=https://cdn.yourdomain.com

# ==========================================
# FFMPEG CONFIGURATION (Public CDN URLs)
# ==========================================
REACT_APP_FFMPEG_CDN_PRIMARY=https://unpkg.com/@ffmpeg/core@0.12.6/dist/umd
REACT_APP_FFMPEG_CDN_FALLBACK=https://cdn.jsdelivr.net/npm/@ffmpeg/core@0.12.6/dist/umd

# ==========================================
# C++ BACKEND SERVER CONFIGURATION
# ==========================================
REACT_APP_CPP_BACKEND_URL=http://localhost:8080
REACT_APP_USE_CPP_BACKEND=true
REACT_APP_ENABLE_NATIVE_ADDON=true
REACT_APP_PREFER_GPU=true
REACT_APP_DEFAULT_QUALITY=high
REACT_APP_MAX_THREADS=0
REACT_APP_MAX_FILE_SIZE_WEB=524288000
REACT_APP_MAX_FILE_SIZE_DESKTOP=0
REACT_APP_ENABLE_BATCH_PROCESSING=true
REACT_APP_MAX_CONCURRENT_CONVERSIONS=4

# ==========================================
# SECURITY CONFIGURATION
# ==========================================
# List of allowed origins for CORS
REACT_APP_CSP_CONNECT_SOURCES=https://api.github.com https://unpkg.com https://cdn.jsdelivr.net
REACT_APP_CORS_ALLOWED_ORIGINS=https://yourdomain.com

# ==========================================
# EMAILJS CONFIGURATION (Sensitive)
# ==========================================
# Get these from your EmailJS dashboard
REACT_APP_EMAILJS_SERVICE_ID=your_emailjs_service_id
REACT_APP_EMAILJS_TEMPLATE_ID=your_emailjs_template_id
REACT_APP_EMAILJS_PUBLIC_KEY=your_emailjs_public_key

# ==========================================
# ANALYTICS & MONITORING (Optional)
# ==========================================
REACT_APP_ANALYTICS_ID=your_analytics_id
REACT_APP_ERROR_REPORTING_KEY=your_error_reporting_key

# ==========================================
# FEATURE FLAGS
# ==========================================
REACT_APP_ENABLE_PREMIUM_FEATURES=true
REACT_APP_ENABLE_EMAIL_MARKETING=true
REACT_APP_ENABLE_ADMIN_PANEL=true

# ==========================================
# DEVELOPMENT SETTINGS
# ==========================================
# Set to true in production for faster builds
GENERATE_SOURCEMAP=false
# Enable/disable React Fast Refresh
FAST_REFRESH=true
# Extend ESLint configuration
EXTEND_ESLINT=false
