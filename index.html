    <!-- Disable React DevTools profiling to prevent errors -->
    <script>
      // ── React 19 addObjectDiffToProperties crash fix ──────────────────────────
      // React 19 unconditionally enables ProfileMode on ALL fiber trees.
      // This causes logComponentRender() → addObjectDiffToProperties() to run on
      // every commit, which crashes when props contain certain values.
      //
      // The entire code path is gated on a module-level variable:
      //
      //   supportsUserTiming = typeof console.timeStamp === 'function'
      //                     && typeof performance.measure === 'function'
      //
      // This variable is computed ONCE when react-dom's CJS module is evaluated.
      // By making console.timeStamp a non-function BEFORE the bundle script loads,
      // React permanently computes supportsUserTiming = false and logComponentRender
      // becomes a no-op, eliminating the crash entirely.
      //
      // We do NOT restore console.timeStamp — in development mode losing Chrome's
      // performance timeline marks is an acceptable trade-off for a stable app.
      // ──────────────────────────────────────────────────────────────────────────
      (function() {
        try {
          Object.defineProperty(console, 'timeStamp', {
            value: null,
            writable: true,
            configurable: true
          });
        } catch (e) {
          try { console.timeStamp = null; } catch (e2) { /* ignore */ }
        }
      })();

      // Must run BEFORE React loads - React 19 DevTools compatibility
      if (typeof window !== 'undefined') {
        const errorPatterns = [
          'addObjectDiffToProperties',
          'logComponentRender',
          'Should not already be working',
          'commitPassiveMountOnFiber',
          'performWorkOnRoot',
          'performWorkOnRootViaSchedulerTask',
          'performWorkUntilDeadline',
          'recursivelyTraversePassiveMountEffects',
          'reading \'toString\''
        ];
        
        const shouldSuppressError = (message) => {
          if (!message) return false;
          const msg = typeof message === 'string' ? message : String(message);
          return errorPatterns.some(pattern => msg.includes(pattern));
        };
        
        const noop = function() {};
        const emptyMap = new Map();
        const emptySet = new Set();
        
        if (!window.__REACT_DEVTOOLS_GLOBAL_HOOK__) {
          window.__REACT_DEVTOOLS_GLOBAL_HOOK__ = {
            checkDCE: noop,
            supportsFiber: true,
            renderers: emptyMap,
            onCommitFiberRoot: noop,
            onCommitFiberUnmount: noop,
            onCommitFiberMount: noop,
            onPostCommitFiberRoot: noop,
            inject: function(renderer) {
              const id = Math.random();
              this.renderers.set(id, renderer);
              return id;
            },
            _listeners: {},
            _renderers: {},
            emit: noop,
            getFiberRoots: function() { return emptySet; },
            on: noop,
            off: noop,
            sub: function() { return noop; },
            isDisabled: true,
            injectProfilingHooks: noop,
            onCommitRoot: noop,
            onCommitUnmount: noop,
            logComponentRender: noop,
            addObjectDiffToProperties: noop
          };
        } else {
          const existingHook = window.__REACT_DEVTOOLS_GLOBAL_HOOK__;
          if (existingHook) {
            try { existingHook.isDisabled = true; } catch(e) {}
            existingHook.logComponentRender = noop;
            existingHook.addObjectDiffToProperties = noop;
            existingHook.injectProfilingHooks = noop;
          }
        }
        
        const originalError = console.error;
        console.error = function(...args) {
          const msg = args[0]?.toString?.() || String(args[0] || '');
          if (!shouldSuppressError(msg)) {
            originalError.apply(console, args);
          }
        };
      }
