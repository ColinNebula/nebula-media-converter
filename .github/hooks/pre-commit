#!/bin/bash

# ============================================
# PRE-COMMIT HOOK - Security Checks
# Prevents committing sensitive data
# ============================================

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo "🔒 Running security pre-commit checks..."

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

# Patterns that indicate secrets
SECRET_PATTERNS=(
    'password\s*[:=]\s*["\x27][^"\x27]{8,}["\x27]'
    'api[_-]?key\s*[:=]\s*["\x27][a-zA-Z0-9]{20,}["\x27]'
    'secret\s*[:=]\s*["\x27][^"\x27]{10,}["\x27]'
    'sk_live_[a-zA-Z0-9]{20,}'
    'pk_live_[a-zA-Z0-9]{20,}'
    'ghp_[a-zA-Z0-9]{36}'
    'AKIA[A-Z0-9]{16}'
    'aws_secret_access_key'
    'private_key'
)

FOUND_SECRETS=0

# Check each staged file
for file in $STAGED_FILES; do
    # Skip certain file types
    if [[ "$file" =~ \.(md|txt|png|jpg|gif|svg|ico)$ ]]; then
        continue
    fi
    
    # Skip if file doesn't exist (deleted)
    if [ ! -f "$file" ]; then
        continue
    fi
    
    # Check for secret patterns
    for pattern in "${SECRET_PATTERNS[@]}"; do
        if grep -qiE "$pattern" "$file" 2>/dev/null; then
            echo -e "${RED}⚠️  Potential secret found in: $file${NC}"
            FOUND_SECRETS=1
        fi
    done
done

# Check for .env files being committed
for file in $STAGED_FILES; do
    if [[ "$file" =~ \.env$ ]] && [[ ! "$file" =~ \.env\.example$ ]]; then
        echo -e "${RED}🚨 BLOCKED: Attempting to commit .env file: $file${NC}"
        echo -e "${YELLOW}   .env files should never be committed!${NC}"
        exit 1
    fi
done

# Check for key/certificate files
for file in $STAGED_FILES; do
    if [[ "$file" =~ \.(pem|key|crt|p12|pfx)$ ]]; then
        echo -e "${RED}🚨 BLOCKED: Attempting to commit sensitive file: $file${NC}"
        exit 1
    fi
done

if [ $FOUND_SECRETS -eq 1 ]; then
    echo ""
    echo -e "${YELLOW}⚠️  Warning: Potential secrets detected in staged files.${NC}"
    echo -e "${YELLOW}   Review carefully before committing.${NC}"
    echo -e "${YELLOW}   To bypass this check, use: git commit --no-verify${NC}"
    echo ""
    # Warning only, don't block (to avoid false positives)
fi

echo -e "${GREEN}✅ Pre-commit security checks passed${NC}"
exit 0
