# Environment Variables for Nebula Media Converter

# Company/App Information
REACT_APP_COMPANY_NAME=Nebula3D Dev Company
REACT_APP_DEVELOPER_NAME=Colin Nebula
REACT_APP_APP_NAME=Nebula Media Converter
REACT_APP_APP_URL=https://colinnebula.github.io/nebula-media-converter/
REACT_APP_SUPPORT_EMAIL=admin@nebuladev.com
REACT_APP_GITHUB_REPO=https://github.com/ColinNebula/nebula-media-converter

# Admin credentials — server-side ONLY (not prefixed with REACT_APP_, never bundled into client JS)
# These are read by backend/dev-server.js at startup.
# To regenerate the hash, run:
#   node -e "const c=require('crypto'),s=c.randomBytes(32).toString('hex'),h=c.pbkdf2Sync('<password>',s,310000,32,'sha256').toString('hex');console.log('ADMIN_PASSWORD_SALT='+s+'\nADMIN_PASSWORD_HASH='+h)"
ADMIN_USERNAME=colinnebula@nebula3ddev.com
ADMIN_EMAIL=colinnebula@nebula3ddev.com
ADMIN_PASSWORD_SALT=67b2400feb451bc4482a3c2fec4e519366f68a92d0fc336367deba17596079ea
ADMIN_PASSWORD_HASH=aa896df233e9051bf75a0bd4543e559f40a67934db5f91aececd4c204958692f

# Payment Integration
REACT_APP_PAYPAL_CLIENT_ID=colinnebula@hotmail.com
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key

# API Configuration
REACT_APP_API_BASE_URL=https://api.nebula3ddev.com
REACT_APP_EMAIL_SERVICE_URL=https://email.nebula3ddev.com
REACT_APP_PAYMENT_API=https://payments.nebula3ddev.com
REACT_APP_CDN_URL=https://cdn.nebula3ddev.com

# FFmpeg Configuration
REACT_APP_FFMPEG_CDN_PRIMARY=https://unpkg.com/@ffmpeg/core@0.12.6/dist/umd
REACT_APP_FFMPEG_CDN_FALLBACK=https://cdn.jsdelivr.net/npm/@ffmpeg/core@0.12.6/dist/umd

# Security Configuration
REACT_APP_CSP_CONNECT_SOURCES=https://api.github.com https://unpkg.com https://cdn.jsdelivr.net
REACT_APP_CORS_ALLOWED_ORIGINS=https://colinnebula.github.io

# EmailJS Configuration
REACT_APP_EMAILJS_SERVICE_ID=service_64j2mwd
REACT_APP_EMAILJS_TEMPLATE_ID=template_64j2mwd
REACT_APP_EMAILJS_PUBLIC_KEY=o7n5LE_OHI9NfL2eU

# Analytics & Monitoring
REACT_APP_ANALYTICS_ID=your_analytics_id
REACT_APP_ERROR_REPORTING_KEY=your_error_reporting_key

# Feature Flags
REACT_APP_ENABLE_PREMIUM_FEATURES=true
REACT_APP_ENABLE_EMAIL_MARKETING=true
REACT_APP_ENABLE_ADMIN_PANEL=true

# Development Settings
# Disable error overlay for React DevTools conflicts
GENERATE_SOURCEMAP=false
# Disable the error overlay completely
ESLINT_NO_DEV_ERRORS=true
# Disable React's runtime error overlay
DISABLE_ESLINT_PLUGIN=true
# Disable service worker (handled per-environment via NODE_ENV check in serviceWorkerRegistration.js)
# Set to true here if you also need to disable it in a production build for debugging.
REACT_APP_DISABLE_SW=false

# Enable file-watch polling on Windows to prevent webpack dev server from missing
# changes and entering a crash/restart loop that causes repeated WS failures.
WATCHPACK_POLLING=true

# WDS (webpack-dev-server) WebSocket — must match the dev server host/port so
# HMR reconnects correctly. Without these CRA 5 / wds-4 can fail silently.
WDS_SOCKET_HOST=localhost
WDS_SOCKET_PORT=3000
WDS_SOCKET_PATH=/ws
# Fast refresh can cause issues with React 19
FAST_REFRESH=false
# TSC won't compile with this enabled, but can suppress some warnings
# TSC_COMPILE_ON_ERROR=true
# Disable problematic browser extension detection
EXTEND_ESLINT=false
